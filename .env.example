PORT=8080
DATASTORE_MODE=memory
TRIGGER_TOKEN=replace-me
API_BASE_URL=http://localhost:8080
SIGNED_URL_TTL_MINUTES=30
DRY_RUN_CLOUD_CALLS=true

# Set DATASTORE_MODE=firestore in cloud environments.
GCP_PROJECT_ID=your-gcp-project-id
CLOUD_SCHEDULER_LOCATION=us-central1
CLOUD_SCHEDULER_JOB_PREFIX=lecture-recorder
CLOUD_SCHEDULER_SERVICE_ACCOUNT=scheduler-invoker@your-gcp-project-id.iam.gserviceaccount.com
CLOUD_RUN_REGION=us-central1
CLOUD_RUN_JOB_NAME=lecture-recorder-worker
CLOUD_RUN_JOB_CONTAINER=lecture-recorder
RECORDINGS_BUCKET=your-recordings-bucket
